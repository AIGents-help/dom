# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DOM_SUBSCRIPTION_CENTS=9900

# SkyWatch insurance (stub — scaffolding only, no real partnership yet)
SKYWATCH_WEBHOOK_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Open Mission Queue — off until enabled. See components/PilotSidebar.tsx.
NEXT_PUBLIC_MISSION_QUEUE_ENABLED=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Drone Operation Management <ops@droneopsman.com>"
# Falls back to RESEND_FROM_EMAIL if unset — only needed if you want a
# separate sender identity for lifecycle/transactional mail.
RESEND_FROM_TRANSACTIONAL=
# From the Resend webhook endpoint config (Svix signing secret, "whsec_...").
RESEND_WEBHOOK_SECRET=
NOTIFY_EMAIL=ops@droneopsman.com

# Optional: enables curl-based testing of /api/dev/test-email without an
# admin session. Leave unset to require real admin auth instead.
DEV_TEST_EMAIL_SECRET=

# Cron (app/api/cron/*) — Vercel automatically sends this as a Bearer token
# on scheduled requests when set. Any random secret works.
CRON_SECRET=

# Notion CRM
NOTION_API_KEY=
NOTION_MISSIONS_DB_ID=
NOTION_LEADS_DB_ID=

# Admin auth (replace with Supabase Auth in production)
ADMIN_EMAIL=admin@droneopsman.com
ADMIN_PASSWORD=
